rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // An admin is any signed-in user whose UID has a document in /admins.
    // Admin docs are created manually in the Firebase console (never by clients).
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{uid} {
      // Admins may read their own record (used by the admin app to verify role).
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Guest-uploaded wedding memories (photos & videos metadata).
    match /memories/{memoryId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.keys().hasAll([
          'imageUrl',
          'timestamp',
          'mediaType',
          'weddingId',
        ])
        && request.resource.data.imageUrl is string
        && request.resource.data.imageUrl.size() > 0
        && request.resource.data.mediaType in ['photo', 'video']
        && request.resource.data.weddingId is string
        && request.resource.data.timestamp == request.time
        && (!('visible' in request.resource.data)
            || request.resource.data.visible == true)
        && (!('guestName' in request.resource.data)
            || request.resource.data.guestName is string)
        && (!('message' in request.resource.data)
            || request.resource.data.message is string)
        && (!('tableNumber' in request.resource.data)
            || request.resource.data.tableNumber is string);

      // Admins may toggle visibility (moderation) but not rewrite other fields.
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['visible'])
        && request.resource.data.visible is bool;

      // Admins may remove memories entirely (Storage cleanup runs server-side).
      allow delete: if isAdmin();
    }

    // Curated content: love story, gallery, messages (admin-managed via console
    // today; admin app CMS lands in a later phase).
    match /wedding_content/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Guest text messages — created by guests, reviewed/removed by admins.
    match /guest_messages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['text', 'timestamp', 'weddingId'])
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 500
        && request.resource.data.timestamp == request.time;
      allow update: if false;
      allow delete: if isAdmin();
    }
  }
}
