rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /weddings/{weddingId}/memories/{fileName} {
      // Guest gallery images use tokenised download URLs; allow reads so photos
      // render in the web/PWA app without extra Storage auth headers.
      allow read: if true;

      allow write: if request.auth != null
        && request.resource.size < 50 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('video/.*')
        );
    }

    // Curated content media uploaded from the admin app. The guest-facing
    // reference (the wedding_content doc) is admin-only in Firestore, so only
    // admin-saved media is ever shown.
    match /weddings/{weddingId}/content/{section}/{fileName} {
      allow read: if true;

      allow write: if request.auth != null
        && request.resource.size < 200 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('video/.*')
          || request.resource.contentType.matches('audio/.*')
        );
    }
  }
}
